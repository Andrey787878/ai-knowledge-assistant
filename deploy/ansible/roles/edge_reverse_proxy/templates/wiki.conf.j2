# Managed by Ansible. Do not edit manually.

upstream wikijs_upstream {
    server {{ nginx_rp_wiki_host }}:{{ nginx_rp_wiki_port }};
    keepalive 32;
}

server {
    listen {{ nginx_rp_http_port }};
    listen [::]:{{ nginx_rp_http_port }};
    server_name {{ nginx_rp_wiki_server_name }};

    location ^~ /.well-known/acme-challenge/ {
        alias {{ nginx_rp_acme_challenge_webroot_path }}/.well-known/acme-challenge/;
        default_type text/plain;
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

{% if nginx_rp_enable_https_server | bool %}
server {
    listen {{ nginx_rp_https_port }} ssl http2;
    listen [::]:{{ nginx_rp_https_port }} ssl http2;
    server_name {{ nginx_rp_wiki_server_name }};

{% include "_tls_security_headers.j2" %}

    server_tokens off;
    client_max_body_size {{ nginx_rp_client_max_body_size }};

    location / {
{% for cidr in nginx_rp_allowed_client_cidrs %}
        allow {{ cidr }};
{% endfor %}
        allow 127.0.0.1/32;
        allow ::1/128;
        deny all;

        proxy_http_version 1.1;
        proxy_pass http://wikijs_upstream;
        proxy_redirect off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_connect_timeout {{ nginx_rp_proxy_connect_timeout }};
        proxy_send_timeout {{ nginx_rp_proxy_send_timeout }};
        proxy_read_timeout {{ nginx_rp_proxy_read_timeout }};
    }

    location = /healthz {
        access_log off;
{% for cidr in nginx_rp_allowed_client_cidrs %}
        allow {{ cidr }};
{% endfor %}
        allow 127.0.0.1/32;
        allow ::1/128;
        deny all;
        default_type text/plain;
        return 200 'ok';
    }
}
{% endif %}

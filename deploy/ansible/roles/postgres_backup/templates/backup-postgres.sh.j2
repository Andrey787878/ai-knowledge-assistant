#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="{{ postgres_backup_root_dir }}"
CURRENT_DIR="{{ postgres_backup_current_dir }}"
CONTAINER="{{ postgres_backup_container_name }}"
ENV_FILE="{{ postgres_backup_env_file }}"
LOCK_FILE="{{ postgres_backup_lock_file }}"
INCLUDE_GLOBALS="{{ 'true' if postgres_backup_include_globals else 'false' }}"
PRUNE_ENABLED="{{ 'true' if postgres_backup_prune_enabled else 'false' }}"
RETENTION_DAYS="{{ postgres_backup_retention_days }}"
BACKUP_TS="$(date +'%Y%m%d-%H%M%S')"
TARGET_DIR="${ROOT_DIR}/${BACKUP_TS}"
LOCK_ACQUIRED="false"

declare -a TMP_DUMP_FILES=(
{% for db_name in postgres_backup_databases %}
  "/tmp/{{ db_name }}.dump"
{% endfor %}
)

is_container_running() {
  docker container ls --filter "name=^/${CONTAINER}$" --filter "status=running" -q | grep -q .
}

cleanup() {
  local rc=$?

  if is_container_running; then
    for tmp_dump in "${TMP_DUMP_FILES[@]}"; do
      docker exec "${CONTAINER}" rm -f "${tmp_dump}" >/dev/null 2>&1 || true
    done
  fi

  if [[ "${LOCK_ACQUIRED}" == "true" ]]; then
    rm -f "${LOCK_FILE}" >/dev/null 2>&1 || true
  fi

  exit "${rc}"
}

trap cleanup EXIT INT TERM

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "env file not found: ${ENV_FILE}" >&2
  exit 1
fi

if ! is_container_running; then
  echo "postgres container is not running: ${CONTAINER}" >&2
  exit 1
fi

mkdir -p "${ROOT_DIR}"

if [[ -f "${LOCK_FILE}" ]]; then
  LOCK_PID="$(cat "${LOCK_FILE}" 2>/dev/null || true)"
  if [[ -n "${LOCK_PID}" && "${LOCK_PID}" =~ ^[0-9]+$ ]] && kill -0 "${LOCK_PID}" 2>/dev/null; then
    echo "another postgres backup process is running (pid: ${LOCK_PID})" >&2
    exit 1
  fi
  rm -f "${LOCK_FILE}" >/dev/null 2>&1 || true
fi

if ! (set -o noclobber; echo "$$" > "${LOCK_FILE}") 2>/dev/null; then
  echo "backup lock file exists: ${LOCK_FILE}" >&2
  exit 1
fi

LOCK_ACQUIRED="true"

read_env_value() {
  local key="$1"
  awk -F= -v key="$key" '
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      line=$0
      sub(/^[[:space:]]*[^=]+[[:space:]]*=[[:space:]]*/, "", line)
      gsub(/\r$/, "", line)
      if ((line ~ /^".*"$/) || (line ~ /^'\''.*'\''$/)) {
        line=substr(line, 2, length(line) - 2)
      }
      print line
      exit
    }
  ' "${ENV_FILE}"
}

POSTGRES_USER="$(read_env_value POSTGRES_USER)"
POSTGRES_PASSWORD="$(read_env_value POSTGRES_PASSWORD)"

if [[ -z "${POSTGRES_USER:-}" || -z "${POSTGRES_PASSWORD:-}" ]]; then
  echo "POSTGRES_USER/POSTGRES_PASSWORD are required in ${ENV_FILE}" >&2
  exit 1
fi

# Avoid putting password into docker exec arguments.
docker_exec_with_pgpassword() {
  printf '%s\n' "${POSTGRES_PASSWORD}" | docker exec -i "${CONTAINER}" sh -eu -c '
    IFS= read -r PGPASSWORD
    export PGPASSWORD
    exec "$@"
  ' sh "$@"
}

mkdir -p "${TARGET_DIR}"

if [[ "${INCLUDE_GLOBALS}" == "true" ]]; then
  docker_exec_with_pgpassword \
    pg_dumpall --globals-only -U "${POSTGRES_USER}" > "${TARGET_DIR}/globals.sql"
fi

{% for db_name in postgres_backup_databases %}
docker_exec_with_pgpassword \
  pg_dump -Fc -U "${POSTGRES_USER}" -d "{{ db_name }}" -f "/tmp/{{ db_name }}.dump"
docker cp "${CONTAINER}:/tmp/{{ db_name }}.dump" "${TARGET_DIR}/{{ db_name }}.dump"
docker exec "${CONTAINER}" rm -f "/tmp/{{ db_name }}.dump"
{% endfor %}

(
  cd "${TARGET_DIR}"
  sha256sum ./* > SHA256SUMS
)

ln -sfn "${TARGET_DIR}" "${CURRENT_DIR}"

if [[ "${PRUNE_ENABLED}" == "true" ]]; then
  find "${ROOT_DIR}" -mindepth 1 -maxdepth 1 -type d -name '20*' -mtime +"${RETENTION_DAYS}" -exec rm -rf {} +
fi

echo "postgres backup completed: ${TARGET_DIR}"

DB_TYPE={{ wikijs_postgres_type }}
DB_HOST={{ wikijs_postgres_host }}
DB_PORT={{ wikijs_postgres_port }}
DB_USER={{ wikijs_postgres_user }}
DB_PASS={{ wikijs_postgres_password }}
DB_NAME={{ wikijs_postgres_database }}

{% if wikijs_postgres_ssl_enabled | bool %}
DB_SSL=true
{% endif %}
{% if wikijs_postgres_ssl_ca | default('') | trim | length > 0 %}
DB_SSL_CA={{ wikijs_postgres_ssl_ca }}
{% endif %}
